# =========================================================================
# Compartido (raíz). Cada servicio tiene además su propio .env.example.
# Copia este archivo a .env y rellena los valores antes de levantar Docker.
# =========================================================================

# ----- MongoDB -----
MONGO_INITDB_ROOT_USERNAME=checkers
MONGO_INITDB_ROOT_PASSWORD=checkers
MONGO_INITDB_DATABASE=checkers
# URL usada por el backend (host = nombre del servicio en compose)
MONGO_URL=mongodb://checkers:checkers@mongo:27017/checkers?authSource=admin

# ----- Backend principal -----
BACKEND_PORT=4000
# URL pública que el frontend usa para hablar con el backend
PUBLIC_BACKEND_URL=http://localhost:4000
# URL del WebSocket
PUBLIC_BACKEND_WS_URL=ws://localhost:4000/ws

# ----- AI service -----
AI_PORT=4100
# El backend habla con la IA por la red interna de Docker
AI_SERVICE_URL=http://ai-service:4100
# Llave compartida entre backend y ai-service (no se expone al cliente)
AI_SERVICE_TOKEN=please-change-me

# ----- Clerk (auth) -----
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Plantilla JWT que el frontend pide a Clerk antes de llamar al backend
CLERK_JWT_TEMPLATE=checkers-backend

# ----- Stripe (pagos) -----
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PREMIUM=price_replace_me
# URL a la que Stripe redirige tras el checkout
STRIPE_SUCCESS_URL=http://localhost:5173/premium?status=success
STRIPE_CANCEL_URL=http://localhost:5173/premium?status=cancel

# ----- Frontend -----
FRONTEND_PORT=5173

# ----- Observabilidad -----
LOG_LEVEL=info
SERVICE_ENV=development
